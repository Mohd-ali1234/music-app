# AI is opt-in: select the provider/model without changing application code.
AI_PROVIDER=qwen
AI_MODEL=qwen2.5
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# Optional: path to a Netscape-format cookies.txt for yt-dlp. Set this if
# YouTube returns "Sign in to confirm you're not a bot" (common on
# datacenter hosts like Render). On Render, add the file as a Secret File
# and point this at its mount path, e.g. /etc/secrets/youtube_cookies.txt
YTDLP_COOKIES_FILE=
