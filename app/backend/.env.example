# AI is opt-in: select the provider/model without changing application code.
AI_PROVIDER=qwen
AI_MODEL=qwen2.5
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# Optional: cookies for yt-dlp, needed if YouTube returns "Sign in to
# confirm you're not a bot" (common on datacenter hosts like Render).
# Either set YTDLP_COOKIES_FILE to an uploaded Secret File's mount path,
# e.g. /etc/secrets/youtube_cookies.txt, OR paste the raw contents of a
# Netscape-format cookies.txt into YTDLP_COOKIES_CONTENT below (simpler:
# works as a plain env var, no Secret File needed).
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_CONTENT=

# Optional (recommended for production): URL of a bgutil-ytdlp-pot-provider
# HTTP server (https://github.com/Brainicism/bgutil-ytdlp-pot-provider).
# Generates a fresh proof-of-origin token per request, bypassing the bot
# check without relying on any account's cookies. e.g.
# https://your-pot-provider.onrender.com or http://127.0.0.1:4416 locally.
YTDLP_POT_PROVIDER_URL=

# Set to true temporarily to log yt-dlp's full internal debug trace (which
# player client/PO-token path was tried and why) for every stream request.
# Verbose - turn off again once you're done diagnosing.
YTDLP_VERBOSE_LOGGING=

# Optional (recommended for production): browser-auth headers for
# ytmusicapi (search). Anonymous search requests are increasingly blocked
# from datacenter IPs (Render, etc.) with an empty/non-JSON response
# ("Expecting value: line 1 column 1"). To fix:
#   1. pip install ytmusicapi (locally, not on the server)
#   2. run `ytmusicapi browser` and follow the prompts (open
#      music.youtube.com while logged in, copy a POST request's headers
#      from DevTools > Network as instructed)
#   3. paste the resulting JSON file's contents below as one line
# This is account session data - keep it out of git, and paste it directly
# into Render's env var UI, not into chat/logs/tickets.
YTMUSIC_AUTH_HEADERS=
