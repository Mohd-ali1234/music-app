# Copy to `.env` and fill in real values. Do not commit `.env`.

# --- Database (MongoDB) ---
# Canonical names. Legacy names MONGO_URL / DB_NAME are still accepted.
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>/?appName=<app>
MONGODB_DB=music_player

# --- Auth ---
# Required in production (the app refuses to start without it). A dev fallback
# is used only when APP_ENV != production.
JWT_SECRET=change-me-to-a-long-random-string

# --- Runtime ---
APP_ENV=development

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:19006

# --- External providers ---
MUSICBRAINZ_USER_AGENT=SemanticMusicPlayer/1.0 (contact: you@example.com)
